# =============================================================================
# CCM API — Test Environment Configuration
#
# Copy this file to .env.test and fill in your local values.
# .env.test is .gitignored and must never be committed.
#
# This file configures integration tests only. Unit tests do not require
# any database connection.
# =============================================================================

# Test PostgreSQL database
# Must be a separate database from the development database to prevent
# test operations from corrupting development data.
TEST_DATABASE_URL=postgresql://ccm:ccm@localhost:5432/ccm_test

# JWT secret — must be at least 32 characters
JWT_SECRET=test-secret-that-is-at-least-32-chars-long

# Node environment for tests
NODE_ENV=test

# Log level — set to 'error' to suppress noise during test runs
LOG_LEVEL=error

# MongoDB — required by config validation but not used in Phase 1 tests
# Set to your local MongoDB or leave as defaults (not actually connected)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=ccm_test
MONGO_USER=ccm
MONGO_PASSWORD=ccm

