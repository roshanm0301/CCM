{
  "name": "@ccm/api",
  "version": "1.0.0",
  "private": true,
  "description": "CCM backend API — Node.js + Express + TypeScript",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "dev": "nodemon --watch src --ext ts --exec tsx src/main.ts",
    "dev:local": "nodemon --config nodemon.local.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --coverage",
    "seed:dealers": "tsx --env-file ../../.env src/scripts/seedDealers.ts",
    "seed:references": "tsx --env-file ../../.env src/scripts/seedReferenceMasters.ts",
    "seed:cti-agents": "tsx --env-file ../../.env src/scripts/seedTeleCmiAgents.ts"
  },
  "dependencies": {
    "@ccm/types": "*",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.4",
    "pg": "^8.13.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
