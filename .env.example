# =============================================================================
# CCM Environment Configuration Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Node environment
# Values: development | production | test
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
PORT=3000

# Log verbosity. Values: error | warn | info | http | debug
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL
# The password must be set to a strong secret in all non-local environments.
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ccm
POSTGRES_USER=ccm_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Full connection URL — constructed from the individual vars above in config/index.ts
# Alternatively provide this directly (takes precedence if set in code).
# POSTGRES_URL=postgresql://ccm_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/ccm

# PostgreSQL connection pool sizing
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# -----------------------------------------------------------------------------
# MongoDB
# Credentials must be set to strong secrets in all non-local environments.
# -----------------------------------------------------------------------------
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=ccm
MONGO_USER=ccm_user
MONGO_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Must match the --replSet value in docker-compose.yml (rs0).
# Set to rs0 for both Docker and local (hybrid) modes.
MONGO_REPLICA_SET=rs0

# Full connection URL — constructed from the individual vars above in config/index.ts
# MONGO_URL=mongodb://ccm_user:REPLACE_WITH_STRONG_PASSWORD@mongo:27017/ccm?authSource=admin

# -----------------------------------------------------------------------------
# JWT Authentication
# Use a strong random secret of at least 64 characters.
# Never share the secret across environments.
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=24h

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins.
# In production lock this down to the actual frontend origin.
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://192.168.3.151:8080

# -----------------------------------------------------------------------------
# Frontend (Vite build-time variables — prefix VITE_)
# These are baked into the browser bundle at build time, not at runtime.
# Do not put secrets here.
# -----------------------------------------------------------------------------
# Leave EMPTY when running via Docker Compose — nginx proxies /api/* to the
# API container transparently and no absolute URL is needed.
# Set to an absolute URL (e.g. https://api.example.com) ONLY when the frontend
# is deployed to a separate origin (CDN / different domain) from the API.
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# TeleCMI CTI
#
# TELECMI_APP_ID       — numeric App ID from TeleCMI portal → App Settings
# TELECMI_APP_SECRET   — App Secret from TeleCMI portal → App Settings
# TELECMI_SBC_URI      — SBC host for WebRTC; sbcind.telecmi.com for India
# TELECMI_WEBHOOK_CUSTOM_VALUE — optional shared secret echoed as `custom`
#                        in every TeleCMI webhook payload. Configure in portal:
#                        Business Number → Settings → Webhooks → Custom value
# TELECMI_BASE_URL     — TeleCMI REST API base URL
# TELECMI_CALLER_ID    — DID/virtual number for outbound calls (digits only,
#                        with country code, e.g. 917943444751)
# -----------------------------------------------------------------------------
TELECMI_APP_ID=REPLACE_WITH_TELECMI_APP_ID
TELECMI_APP_SECRET=REPLACE_WITH_TELECMI_APP_SECRET
TELECMI_SBC_URI=sbcind.telecmi.com
TELECMI_WEBHOOK_CUSTOM_VALUE=REPLACE_WITH_WEBHOOK_CUSTOM_VALUE
TELECMI_BASE_URL=https://rest.telecmi.com
TELECMI_CALLER_ID=REPLACE_WITH_DID_NUMBER_DIGITS_ONLY

# -----------------------------------------------------------------------------
# pgAdmin (devtools profile only — never in production)
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=REPLACE_WITH_LOCAL_PGADMIN_PASSWORD

# -----------------------------------------------------------------------------
# mongo-express (devtools profile only — never in production)
# -----------------------------------------------------------------------------
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=REPLACE_WITH_LOCAL_MONGOEXPRESS_PASSWORD
