# =============================================================================
# CCM — Environment variable reference
#
# Copy this file to .env at the repository root and fill in real values before
# running locally. Rename the copy to .env (with the leading dot).
# NEVER commit .env to version control.
# Staging and production values must be injected via a secrets manager,
# not sourced from this file.
# =============================================================================

# ---------------------------------------------------------------------------
# Application runtime
# ---------------------------------------------------------------------------

# Development override — do not use in staging or production
NODE_ENV=development

LOG_LEVEL=info

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=ccm
POSTGRES_USER=ccm_user
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGO_DB=ccm
MONGO_USER=ccm_user
MONGO_PASSWORD=changeme
MONGO_PORT=27017
# Replica set name — must match the --replSet flag in docker-compose.yml.
# Required for Mongoose transactions (cascade inactivation).
MONGO_REPLICA_SET=rs0

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
JWT_SECRET=changeme-use-a-long-random-secret-in-production
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=24h

# ---------------------------------------------------------------------------
# API / CORS
# ---------------------------------------------------------------------------
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ---------------------------------------------------------------------------
# Cookie security
# ---------------------------------------------------------------------------
#
# Controls the Secure flag on session/CSRF cookies and the __Host- prefix
# on the CSRF cookie name.  Set to 'true' ONLY when the app is served over
# HTTPS (TLS).  Defaults to 'false' so HTTP deployments (Docker Compose
# without TLS, LAN access via IP) work out-of-the-box.
#
# COOKIE_SECURE=true   → Secure flag set, __Host-ccm-csrf cookie name
# COOKIE_SECURE=false  → No Secure flag, plain ccm-csrf cookie name
COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# HTTPS for Vite dev server (LAN / IP access)
# ---------------------------------------------------------------------------
#
# When accessing the app from a LAN IP (e.g. http://192.168.x.x:8080),
# browser APIs like getUserMedia (microphone) and WebRTC are blocked
# because they require a "secure context" (HTTPS or localhost).
#
# Set VITE_HTTPS=true to enable HTTPS on the Vite dev server with a
# self-signed certificate.  You will need to accept the browser's
# certificate warning once when first visiting the page.
#
# When enabled, access the app via:
#   https://localhost:8080       (instead of http://)
#   https://192.168.x.x:8080    (instead of http://)
#
# Also add the https:// origins to CORS_ALLOWED_ORIGINS, e.g.:
#   CORS_ALLOWED_ORIGINS=https://localhost:8080,https://192.168.3.151:8080
VITE_HTTPS=false

# ---------------------------------------------------------------------------
# Frontend (build-time)
# ---------------------------------------------------------------------------
#
# VITE_API_BASE_URL controls where the frontend sends API requests.
#
# Containerised stack (docker-compose.yml — default):
#   Leave EMPTY. nginx proxies /api/* to ccm-api:3000 transparently.
#   Browser stays on the same origin (port 8080) — no CORS needed.
#
# Local Vite dev server (npm run dev — without Docker):
#   Set to the API server URL so the Vite dev proxy can forward requests.
#   Uncomment the line below for local Vite dev server usage:
#   VITE_API_BASE_URL=http://localhost:3000
#
# Docker Compose default — leave empty:
VITE_API_BASE_URL=
